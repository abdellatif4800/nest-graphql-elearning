{
  "name": "lms-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build:admin-api": "nest build admin-api",
    "build:user-api": "nest build user-api",
    "build": "npm run build:admin-api && npm run build:user-api",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/lms-api/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/lms-api/test/jest-e2e.json",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "dev:adminApi": "NODE_OPTIONS='--max-old-space-size=512' nest start --watch admin-api",
    "dev:publicApi": "NODE_OPTIONS='--max-old-space-size=512' nest start --watch user-api",
    "dev": "concurrently -n Admin,Public -c magenta,blue \"pnpm run dev:adminApi\" \"pnpm run dev:publicApi\""
  },
  "dependencies": {
    "@apollo/server": "^5.3.0",
    "@as-integrations/express5": "^1.1.2",
    "@google/genai": "^1.40.0",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@vendia/serverless-express": "^4.12.6",
    "ai": "^6.0.78",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "graphql-upload": "^17.0.0",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.6",
    "pg": "^8.17.2",
    "postgres": "^3.4.8",
    "prisma": "^7.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serverless-http": "^4.0.0",
    "slugify": "^1.6.6",
    "ts-morph": "^27.0.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^apiLibs/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^apiLibs/drizzle(|/.*)$": "<rootDir>/libs/drizzle/src/$1",
      "^apiLibs/graphql-models(|/.*)$": "<rootDir>/libs/graphql-models/src/$1",
      "^apiLibs/graphql-schema(|/.*)$": "<rootDir>/libs/graphql-schema/src/$1",
      "^apiLibs/libs/auth(|/.*)$": "<rootDir>/libs/libs/auth/src/$1",
      "^apiLibs/prisma-setup(|/.*)$": "<rootDir>/libs/prisma-setup/src/$1",
      "^apiLibs/tutorials-management(|/.*)$": "<rootDir>/libs/tutorials-management/src/$1",
      "^apiLibs/typeorm-setup(|/.*)$": "<rootDir>/libs/typeorm-setup/src/$1",
      "^apiLibs/users-managment(|/.*)$": "<rootDir>/libs/users-managment/src/$1"
    }
  }
}
