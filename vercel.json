{
  "version": 2,
  "functions": {
    "apps/admin-api/main.ts": { "runtime": "@vercel/node@2.0.0" },
    "apps/user-api/main.ts": { "runtime": "@vercel/node@2.0.0" }
  },
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "apps/admin-api/main.ts" },
    { "source": "/user/(.*)", "destination": "apps/user-api/main.ts" }
  ]
}
