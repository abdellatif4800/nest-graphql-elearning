{
  "version": 2,
  "functions": {
    "api/admin/main.js": { "runtime": "@vercel/node@2.0.0" },
    "api/user/main.js": { "runtime": "@vercel/node@2.0.0" }
  },
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "api/admin/main.js" },
    { "source": "/user/(.*)", "destination": "api/user/main.js" }
  ]
}
