{
  "version": 2,
  "functions": {
    "dist/apps/admin-api/main.js": { "runtime": "@vercel/node@2.0.0" },
    "dist/apps/user-api/main.js": { "runtime": "@vercel/node@2.0.0" }
  },
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "dist/apps/admin-api/main.js" },
    { "source": "/user/(.*)", "destination": "dist/apps/user-api/main.js" }
  ]
}
