{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "apiLibs/common": [
        "libs/common/src"
      ],
      "apiLibs/common/*": [
        "libs/common/src/*"
      ],
      "apiLibs/libs/auth": [
        "libs/libs/auth/src"
      ],
      "apiLibs/libs/auth/*": [
        "libs/libs/auth/src/*"
      ],
      "apiLibs/prisma-setup": [
        "libs/prisma-setup/src"
      ],
      "apiLibs/prisma-setup/*": [
        "libs/prisma-setup/src/*"
      ],
      "apiLibs/tutorials-management": [
        "libs/tutorials-management/src"
      ],
      "apiLibs/tutorials-management/*": [
        "libs/tutorials-management/src/*"
      ],
      "apiLibs/typeorm-setup": [
        "libs/typeorm-setup/src"
      ],
      "apiLibs/typeorm-setup/*": [
        "libs/typeorm-setup/src/*"
      ],
      "apiLibs/users-managment": [
        "libs/users-managment/src"
      ],
      "apiLibs/users-managment/*": [
        "libs/users-managment/src/*"
      ]
    }
  }
}