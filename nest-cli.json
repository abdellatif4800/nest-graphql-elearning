{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "sourceRoot": "apps",
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "tsconfig.build.json"
  },
  "projects": {
    "admin-api": {
      "type": "application",
      "root": "apps/admin-api",
      "entryFile": "main",
      "sourceRoot": "apps/admin-api/src",
      "compilerOptions": {
        "webpack": false,
        "tsConfigPath": "apps/admin-api/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "tutorials-management": {
      "type": "library",
      "root": "libs/tutorials-management",
      "entryFile": "index",
      "sourceRoot": "libs/tutorials-management/src",
      "compilerOptions": {
        "tsConfigPath": "libs/tutorials-management/tsconfig.lib.json"
      }
    },
    "user-api": {
      "type": "application",
      "root": "apps/user-api",
      "entryFile": "main",
      "sourceRoot": "apps/user-api/src",
      "compilerOptions": {
        "webpack": false,
        "tsConfigPath": "apps/user-api/tsconfig.app.json"
      }
    },
    "users-managment": {
      "type": "library",
      "root": "libs/users-managment",
      "entryFile": "index",
      "sourceRoot": "libs/users-managment/src",
      "compilerOptions": {
        "tsConfigPath": "libs/users-managment/tsconfig.lib.json"
      }
    }
  }
}
